# Copy to .env and fill in (never commit .env). Used by news + open context + Ollama.

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: extra headlines (https://finnhub.io)
# FINNHUB_API_KEY=

# Optional: NewsAPI.org (check their license for your use case)
# NEWSAPI_KEY=

# Optional: CourtListener (https://www.courtlistener.com/help/api/)
# COURTLISTENER_API_KEY=

# Reddit JSON fetch User-Agent (identify your app per Reddit API rules)
# REDDIT_USER_AGENT=YourApp:1.0 (by /u/yourname)
